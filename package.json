{
  "name": "websites",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --ui=tui",
    "start": "pnpm --filter blog start",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "format": "prettier --write **/*.{css,html,js,json,md,mjs,scss,ts,tsx,yaml,yml} --max-warnings=0",
    "format:check": "prettier --check **/*.{css,html,js,json,md,mjs,scss,ts,tsx,yaml,yml}",
    "postinstall": "git config core.hooksPath .githooks"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "prettier": "3.8.1",
    "turbo": "2.8.20",
    "typescript": "6.0.2"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || ^24.12.0"
  },
  "packageManager": "pnpm@9.0.0"
}
