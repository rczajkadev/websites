{
  "name": "websites",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --ui=tui",
    "start": "pnpm --filter blog start",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "format": "prettier --write **/*.{css,html,js,json,md,mjs,scss,ts,tsx,yaml,yml}"
  },
  "devDependencies": {
    "prettier": "3.8.1",
    "turbo": "2.8.12",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=24.12.0"
  },
  "packageManager": "pnpm@9.0.0"
}
